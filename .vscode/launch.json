{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension - Webview HMR",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/extension/**/*.js"
      ],
      "preLaunchTask": "dev: extension watch + webview hmr",
      "env": {
        "VSCODE_WEBVIEW_DEV_SERVER": "http://localhost:31773"
      }
    },
    {
      "name": "Run Extension - Build",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/extension/**/*.js"
      ],
      "preLaunchTask": "npm: build"
    }
  ]
}
