{
  "name": "limcode-vscode-assistant",
  "displayName": "LimCode",
  "description": "VS Code extension with a TypeScript ECS backend, Vue webview frontend, and a basic AI chat flow.",
  "version": "0.0.1",
  "publisher": "your-publisher",
  "private": true,
  "engines": {
    "vscode": "^1.89.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension/vscode/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "limcode.openPanel",
        "title": "LimCode: Open AI Chat",
        "category": "LimCode"
      },
      {
        "command": "limcode.configureApiKey",
        "title": "LimCode: Configure OpenAI Compatible API Key",
        "category": "LimCode"
      },
      {
        "command": "limcode.revealGlobalStorage",
        "title": "LimCode: Reveal Global Storage Folder",
        "category": "LimCode"
      }
    ],
    "configuration": {
      "title": "LimCode",
      "properties": {
        "limcode.openAiCompatible.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com/v1",
          "description": "OpenAI-compatible API base URL. The extension appends /chat/completions when needed."
        },
        "limcode.openAiCompatible.model": {
          "type": "string",
          "default": "deepseek-v4-falsh",
          "description": "Default OpenAI-compatible model used by LimCode."
        },
        "limcode.openAiCompatible.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "Default sampling temperature."
        },
        "limcode.openAiCompatible.enableTools": {
          "type": "boolean",
          "default": false,
          "description": "Whether to send registered tool schemas to the OpenAI-compatible provider. Disabled for the initial basic chat flow."
        },
        "limcode.openAiCompatible.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional API key fallback. Prefer the command `LimCode: Configure OpenAI Compatible API Key` or environment variables `LIMCODE_OPENAI_API_KEY` / `DEEPSEEK_API_KEY` so secrets are not stored in settings files."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "limcode-sidebar",
          "title": "LimCode",
          "icon": "assets/icons/activity-bar.svg"
        }
      ]
    },
    "views": {
      "limcode-sidebar": [
        {
          "id": "limcode-entry-view",
          "name": "AI 对话",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "clean:extension": "node -e \"require('fs').rmSync('dist/extension',{recursive:true,force:true})\"",
    "compile": "npm run clean:extension && tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "build:webview": "vite build",
    "dev:webview": "vite --host 127.0.0.1 --port 31773 --strictPort",
    "build": "npm run compile && npm run build:webview",
    "typecheck:webview": "vue-tsc -p tsconfig.webview.json --noEmit",
    "check": "npm run compile && npm run typecheck:webview",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.89.0",
    "@vitejs/plugin-vue": "^5.0.5",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vue": "^3.4.31",
    "vue-tsc": "^2.0.26"
  }
}
